# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project: outputs (regenerable, doesn't belong in the repo)
# Big per-run files (predictions and partial checkpoints are 10+ MB each)
results/**/*__predictions.json
results/**/*__checkpoint_partial.json
outputs/
*.log
wandb/

# Project: model weights and large data (live on disk, not in git)
*.bin
*.safetensors
*.pt
*.pth
checkpoints/

# Project: cloned upstream code (we clone HuatuoGPT-Vision separately at runtime)
HuatuoGPT-Vision/

# Project: downloaded eval data (large, lives on disk)
Medical_Multimodal_Evaluation_Data/

# Exceptions: keep small result artifacts under version control.
# Predictions and partial checkpoints stay ignored (too large).
!results/**/*__scores.json
!results/**/*__latency_summary.json
!results/**/eval.log
!results/**/*_summary.txt
!results/v2_pre_llm/.gitkeep
!results/v1_post_layer0/.gitkeep
